# Future local persistence path for Task 03.
DATABASE_URL=./data/japanese-custom-study.db
DATABASE_AUTH_TOKEN=

# Root folder for editorial Markdown content imports.
CONTENT_ROOT=./content/media

# Optional app auth for public deployment.
AUTH_USERNAME=
AUTH_PASSWORD_HASH=
AUTH_PASSWORD=
AUTH_SESSION_SECRET=

# Optional webhook used by `pnpm content:import` to invalidate deployed
# Next/Vercel caches after a successful content sync.
CONTENT_CACHE_REVALIDATE_URL=
CONTENT_CACHE_REVALIDATE_SECRET=

# Optional timeout in ms for each FSRS optimizer preset training run.
FSRS_OPTIMIZER_TRAINING_TIMEOUT_MS=
