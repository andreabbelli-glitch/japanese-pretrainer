{
  "name": "japanese-custom-study",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "start:e2e": "node --disable-warning=DEP0040 --experimental-strip-types --experimental-default-type=module ./scripts/start-e2e.ts",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:e2e:runner": "env -u NO_COLOR node ./node_modules/@playwright/test/cli.js test",
    "test:e2e": "pnpm build && pnpm test:e2e:runner",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "node --experimental-strip-types --experimental-default-type=module ./scripts/db-migrate.ts",
    "db:backfill-review-subject-state": "node --experimental-strip-types --experimental-default-type=module ./scripts/db-backfill-review-subject-state.ts",
    "db:seed": "node --experimental-strip-types --experimental-default-type=module ./scripts/db-seed.ts",
    "content:validate": "node --experimental-strip-types --experimental-default-type=module ./scripts/validate-content.ts",
    "content:import": "node --experimental-strip-types --experimental-default-type=module ./scripts/import-content.ts",
    "content:test-stats": "node --experimental-strip-types --experimental-default-type=module ./scripts/update-real-bundle-test-stats.ts",
    "pronunciations:fetch": "node --experimental-strip-types --experimental-default-type=module ./scripts/fetch-pronunciations.ts",
    "pronunciations:pending": "node --experimental-strip-types --experimental-default-type=module ./scripts/update-pronunciation-pending.ts",
    "pronunciations:reuse": "node --experimental-strip-types --experimental-default-type=module ./scripts/reuse-pronunciations.ts",
    "pitch-accents:fetch": "node --experimental-strip-types --experimental-default-type=module ./scripts/fetch-pitch-accents.ts",
    "pronunciations:forvo": "node --experimental-strip-types --experimental-default-type=module ./scripts/fetch-forvo-pronunciations.ts",
    "image:status": "node --experimental-strip-types --experimental-default-type=module ./scripts/image-workflow-status.ts",
    "image:apply": "node --experimental-strip-types --experimental-default-type=module ./scripts/apply-image-blocks.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "auth:hash-password": "node --experimental-strip-types --experimental-default-type=module ./scripts/hash-auth-password.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "release:check": "./scripts/release-check.sh"
  },
  "dependencies": {
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@fontsource/biz-udpgothic": "^5.2.9",
    "@fontsource/newsreader": "^5.2.10",
    "@libsql/client": "^0.17.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-parse": "^11.0.0",
    "ts-fsrs": "^5.2.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
